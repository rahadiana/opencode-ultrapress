{
  "name": "@rahadiana/opencode-ultrapress",
  "version": "0.2.11",
  "description": "Token compression plugin for OpenCode AI — multi-layer filtering, semantic compression, and dynamic context pruning.",
  "homepage": "https://github.com/rahadiana/opencode-ultrapress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahadiana/opencode-ultrapress.git"
  },
  "bugs": {
    "url": "https://github.com/rahadiana/opencode-ultrapress/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/*.node",
    "ultrapress.schema.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"require('fs').readdirSync('dist').filter(f=>f.endsWith('.node')).forEach(f=>require('fs').unlinkSync('dist/'+f))\"",
    "dev": "tsup --watch",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "benchmark": "tsx benchmarks/run.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "plugin",
    "compression",
    "token",
    "context",
    "pruning",
    "llm"
  ],
  "author": "rahadiana nugraha <rahadiana.nugraha@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
