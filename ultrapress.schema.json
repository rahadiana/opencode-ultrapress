{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rahadiana/opencode-ultrapress/main/ultrapress.schema.json",
  "title": "UltraPress Configuration",
  "description": "Configuration schema for UltraPress — token compression plugin for OpenCode AI.",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Master switch for the entire plugin.",
      "default": true
    },
    "enableDebug": {
      "type": "boolean",
      "description": "Enable UltraPress console logs. When false, logs are fully silent.",
      "default": false
    },
    "notification": {
      "type": "string",
      "enum": ["off", "minimal", "detailed"],
      "description": "Log verbosity level (used only when enableDebug=true).",
      "default": "minimal"
    },
    "outputFilter": {
      "type": "object",
      "description": "Layer 1 — Tool output filtering.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "maxCharsPerOutput": { "type": "number", "default": 6000 },
        "teeSaveOnTruncate": { "type": "boolean", "default": true },
        "customFilters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "commandPattern": { "type": "string", "description": "Regex pattern to match tool command" },
              "stripPatterns": { "type": "array", "items": { "type": "string" }, "description": "Lines matching these patterns are removed" },
              "keepPatterns": { "type": "array", "items": { "type": "string" }, "description": "Lines matching these patterns are always kept" },
              "maxLines": { "type": "number", "description": "Maximum lines in filtered output" }
            },
            "required": ["commandPattern"]
          },
          "default": []
        },
        "skipTools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tool names to skip filtering. Safety guard: `task` is always enforced internally even if omitted in user config.",
          "default": ["task"]
        }
      }
    },
    "semantic": {
      "type": "object",
      "description": "Layer 2 — Semantic compression.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "mode": { "type": "string", "enum": ["nlp", "mlm", "llm"], "default": "nlp" },
        "model": { "type": "string", "default": "Xenova/all-MiniLM-L6-v2" },
        "compressUserMessages": { "type": "boolean", "default": true },
        "compressAssistantMessages": { "type": "boolean", "default": false },
        "compressToolOutputs": { "type": "boolean", "default": true },
        "protectCodeBlocks": { "type": "boolean", "default": true },
        "protectErrors": { "type": "boolean", "default": true },
        "minLengthChars": { "type": "number", "default": 250 },
        "skipTools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tool names to skip semantic compression. Safety guard: `task` is always enforced internally even if omitted in user config.",
          "default": ["task"]
        }
      }
    },
    "summarization": {
      "type": "object",
      "default": {},
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Layer 3 placeholder compression"
        },
        "preserveLastN": {
          "type": "integer",
          "default": 4,
          "minimum": 0,
          "description": "Preserve last N messages from placeholder compression (0 = compress all)"
        }
      }
    },
    "commands": {
      "type": "object",
      "description": "Slash command configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": true, "description": "Enable /up slash commands." }
      }
    },
    "cleanup": {
      "type": "object",
      "description": "Layer 4 — Deduplication & error purging.",
      "properties": {
        "deduplication": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          }
        },
        "purgeErrors": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "turns": { "type": "number", "default": 4 }
          }
        }
      }
    }
  }
}
